FROM ubuntu:24.04@sha256:186072bba1b2f436cbb91ef2567abca677337cfc786c86e107d25b7072feef0c

# Install systemd for journalctl (required by journaldreceiver)
RUN apt-get update && \
    apt-get install -y systemd && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Verify journalctl is available at build time
RUN journalctl --version

COPY --chmod=755 dynatrace-otel-collector /dynatrace-otel-collector

ENTRYPOINT ["/dynatrace-otel-collector"]
CMD ["--config=/conf/config.yaml"]
